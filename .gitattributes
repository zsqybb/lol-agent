# 统一换行符：所有文本文件使用 LF
* text=auto eol=lf

# Python 源文件
*.py text eol=lf

# Web 前端
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf

# 配置文件
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# 二进制文件
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary

# Windows Batch 脚本保留 CRLF
*.bat text eol=crlf
